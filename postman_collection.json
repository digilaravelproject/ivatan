    {
      "name": "4. Admin - Profile Approval",
      "item": [
        {
          "name": "List Pending Switch Requests",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/profile-switch-requests?profile_type=&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "profile-switch-requests"],
              "query": [
                { "key": "profile_type", "value": "", "description": "Filter by profile type (employer, seller, etc.)" },
                { "key": "per_page", "value": "20", "description": "Items per page" }
              ]
            }
          }
        },
        {
          "name": "Get Switch Request Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/admin/profile-switch-requests/{{request_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "profile-switch-requests", "{{request_id}}"]
            }
          }
        },
        {
          "name": "Approve Switch Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"approved\",\n    \"admin_notes\": \"Verified documents. Profile switch approved.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/admin/profile-switch-requests/{{request_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "profile-switch-requests", "{{request_id}}", "approve"]
            }
          }
        },
        {
          "name": "Reject Switch Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"rejected\",\n    \"admin_notes\": \"Documents not verified. Please re-submit.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/admin/profile-switch-requests/{{request_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["v1", "admin", "profile-switch-requests", "{{request_id}}", "approve"]
            }
          }
        }
      ]
    },
